    "ts-morph": "^28.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
